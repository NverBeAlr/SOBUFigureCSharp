@using SOBUFigure.Models
@rendermode InteractiveServer
@using SOBUFigure.Services.Admins
@page "/Admins/Create"
@inject IAdminService AdminService

<h3>Create</h3>

<EditForm Model="admin" FormName="createAdmin" OnInvalidSubmit="SaveAdmin">
    <DataAnnotationsValidator>
        <div class="form-group">
            <lable>Name: </lable>
            <InputText @bind-Value="admin.Name"/>
            <ValidationMessage For="() => admin.Name"/>
        </div>
        
        <div class="form-group">
            <lable>Email: </lable>
            <InputText @bind-Value="admin.Email"/>
            <ValidationMessage For="() => admin.Email"/>
        </div>
        
        <div class="form-group">
            <lable>Password: </lable>
            <InputText @bind-Value="admin.Password"/>
            <ValidationMessage For="() => admin.Password"/>
        </div>
        
        <div class="form-group">
            <lable>Phone number: </lable>
            <InputNumber @bind-Value="admin.Phone_number"/>
            <ValidationMessage For="() => admin.Phone_number"/>
        </div>
        
        <div class="form-group">
            <lable>Role: </lable>
            <InputNumber @bind-Value="admin.Role"/>
            <ValidationMessage For="() => admin.Role"/>
        </div>
        
        <div class="form-group">
            <button class="btn btn-primary" type="submit">
                Save
            </button>
        </div>
    </DataAnnotationsValidator>
</EditForm>

@code {
    public Admin admin = new Admin();
    [Inject] NavigationManager _navigationManager { get; set; }

    private async Task SaveAdmin()
    {
        await AdminService.CreateAdminAsync(admin);
        _navigationManager.NavigateTo("/Admins", true);
    }
}